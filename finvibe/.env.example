# ═══════════════════════════════════════════════════════════
#  FinVibe — Environment Variables Template
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# --- LLM (Groq — FREE at console.groq.com) ---
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Fallback: Gemini (optional) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- MongoDB Atlas (FREE M0 cluster at mongodb.com/atlas) ---
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=finvibe_db

# --- Qdrant Cloud (FREE 1GB at cloud.qdrant.io) ---
QDRANT_URL=https://your-cluster-id.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# --- Neo4j Aura (FREE at neo4j.com/cloud — optional, Mem0 graph memory) ---
NEO_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO_USERNAME=neo4j
NEO_PASSWORD=your_neo4j_password

# --- Financial Modeling Prep (FREE at financialmodelingprep.com) ---
FMP_API_KEY=your_fmp_key_here

# --- News API (optional) ---
NEWS_API_KEY=

# --- VAPI (optional voice agent) ---
VAPI_API_KEY=

# --- CORS (add your Vercel domain) ---
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-app.vercel.app
