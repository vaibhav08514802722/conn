# ─────────────────────────────────────────────────────────────────────────────
# Law Chatbot — Environment Variables
# Copy this file to .env and fill in your actual values.
# ─────────────────────────────────────────────────────────────────────────────

# LLM — Groq API key (https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Vector store — Qdrant (local Docker default)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=law_documents

# Database — MongoDB (local Docker default)
MONGO_URI=mongodb://localhost:27017
MONGO_DB=lawchatbot

# Authentication
JWT_SECRET=change_this_to_a_long_random_string_in_production

# Embedding model (HuggingFace, runs locally)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LLM config
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048

# Ingestion config
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=6

# Redis (for background jobs)
REDIS_URL=redis://localhost:6379

# CORS (comma-separated allowed origins)
ALLOWED_ORIGINS=http://localhost:3000
RETRIEVAL_TOP_K=6

# Redis / Valkey — background job queue
REDIS_URL=redis://localhost:6379
